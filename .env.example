# === Project ===
COMPOSE_PROJECT_NAME=lead-capture
LOG_LEVEL=INFO

# === Shared AI / Sheets ===
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GOOGLE_SHEETS_ID=your_google_spreadsheet_id
GOOGLE_SHEET_NAME=Leads
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=1
LOCAL_TIMEZONE=UTC

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_token
POLL_INTERVAL_SECONDS=1

# === Web Assistant ===
WEB_ASSISTANT_HOST=0.0.0.0
WEB_ASSISTANT_PORT=5000

# === Reverse Proxy ===
NGINX_HTTP_PORT=80

# === Production images ===
# TELEGRAM_BOT_IMAGE=ghcr.io/your-org/pe44-telegram-bot:v1.0.0
# WEB_ASSISTANT_IMAGE=ghcr.io/your-org/pe44-web-assistant:v1.0.0
