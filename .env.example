# === Project ===
COMPOSE_PROJECT_NAME=lead-capture
LOG_LEVEL=INFO

# === Shared AI ===
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
CADDY_LOG_LEVEL=INFO
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=1
LOCAL_TIMEZONE=UTC
DB_CONNECT_TIMEOUT_SECONDS=5
MAX_REQUEST_SIZE=1MB

# === PostgreSQL ===
POSTGRES_DB=lead_capture
POSTGRES_USER=lead_capture_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lead_capture_user:change_me@postgres:5432/lead_capture

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_token
POLL_INTERVAL_SECONDS=1

# === Web Assistant ===
WEB_ASSISTANT_HOST=0.0.0.0
WEB_ASSISTANT_PORT=5000
LEADS_VIEW_TOKEN=change_this_token_for_leads_page

# === Reverse Proxy ===
CADDY_SITE_HOST=localhost
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# === Production images ===
# TELEGRAM_BOT_IMAGE=ghcr.io/your-org/pe44-telegram-bot:v1.0.0
# WEB_ASSISTANT_IMAGE=ghcr.io/your-org/pe44-web-assistant:v1.0.0
